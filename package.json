{
  "name": "boop-search",
  "displayName": "boop-search",
  "description": "Open files in your codebase using natural language queries powered by local embeddings",
  "version": "0.1.1",
  "publisher": "PratiekSonare",
  "icon": "resources/boop-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/PratiekSonare/boop-search"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "code-navigation",
    "productivity",
    "semantic-search",
    "embeddings"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "boop",
          "title": "Boop",
          "icon": "extension-icon.png"
        }
      ]
    },
    "views": {
      "boop": [
        {
          "type": "webview",
          "id": "boop.sidebar",
          "icon": "extension-icon.png",
          "name": ""
        }
      ]
    },
    "commands": [
      {
        "command": "boop.openByDescription",
        "title": "Open Files by Description",
        "category": "boop"
      },
      {
        "command": "boop.addHeader",
        "title": "Add File Purpose Header",
        "category": "boop"
      },
      {
        "command": "boop.rebuildIndex",
        "title": "Rebuild Metadata Index",
        "category": "boop"
      },
      {
        "command": "boop.configureProvider",
        "title": "Configure LLM Provider",
        "category": "boop"
      }
    ],
    "keybindings": [
      {
        "command": "boop.openByDescription",
        "key": "ctrl+shift+alt+F",
        "when": "editorFocus"
      },
      {
        "command": "boop.rebuildIndex",
        "key": "ctrl+shift+alt+R",
        "when": "editorFocus"
      }
    ],
    "configuration": {
      "title": "Boop",
      "properties": {
        "boop.searchMethod": {
          "type": "string",
          "enum": [
            "embeddings",
            "llm"
          ],
          "default": "embeddings",
          "description": "Search method: 'embeddings' (fast, offline) or 'llm' (intelligent, requires API key)"
        },
        "boop.llmProvider": {
          "type": "string",
          "enum": [
            "gemini",
            "openai",
            "openrouter"
          ],
          "default": "gemini",
          "description": "LLM provider for search and auto-summarization"
        },
        "boop.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "**Required if using Gemini provider.** Google Gemini API key (get from https://aistudio.google.com/app/apikey)."
        },
        "boop.geminiModel": {
          "type": "string",
          "default": "gemini-3.5-flash",
          "description": "Gemini model to use (e.g., gemini-3.5-flash, gemini-3.1-pro, gemini-2.5-pro)"
        },
        "boop.openaiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "**Required if using OpenAI provider.** OpenAI API key (get from https://platform.openai.com/api-keys)."
        },
        "boop.openaiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "OpenAI model to use (e.g., gpt-4o, gpt-4o-mini, gpt-3.5-turbo)"
        },
        "boop.openRouterApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "**Required if using OpenRouter provider.** OpenRouter API key (get from https://openrouter.ai/keys)."
        },
        "boop.openRouterModel": {
          "type": "string",
          "default": "anthropic/claude-3-haiku",
          "description": "OpenRouter model ID (e.g., anthropic/claude-3-haiku, openai/gpt-4o-mini)"
        },
        "boop.maxResultsShown": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of files to show in the quick-pick results"
        },
        "boop.autoSummarizeOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Auto-generate @purpose summaries for files without headers on first startup (requires Gemini API key)"
        },
        "boop.includePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.{ts,tsx,js,jsx,py,go,rs,java,rb,sql,json,yaml,yml,toml,md,css,scss,html}"
          ],
          "description": "Glob patterns for files to include in the index"
        },
        "boop.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/.next/**",
            "**/coverage/**"
          ],
          "description": "Glob patterns for files to exclude from the index"
        },
        "boop.enableFileWatcher": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update the index when files are created, deleted, or modified"
        },
        "boop.enableSymbolExtraction": {
          "type": "boolean",
          "default": true,
          "description": "Extract function, class, interface, and method names from files using LSP. Faster indexing when disabled."
        },
        "boop.rootFolderPath": {
          "type": "string",
          "default": "",
          "description": "Root folder path to scan from. Leave empty to scan the entire workspace."
        }
      }
    }
  },
  "scripts": {
    "build:css": "tailwindcss -i src/sidebar/styles.css -o dist/sidebar.css",
    "compile": "node esbuild.config.js",
    "build": "npm run build:css && npm run compile",
    "watch": "node esbuild.config.js --watch",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "package": "vsce package",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.3.0",
    "@xenova/transformers": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
